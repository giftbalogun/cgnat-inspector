#!/usr/bin/env bash
# cgnat-inspector
# Detect Carrier Grade NAT (CGNAT) using multiple independent
# networking tests, weighed as evidence into a confidence score rather
# than concluded from any single signal.
#
# https://github.com/giftbalogun/cgnat-inspector
#
# Exit codes:
#   0  Public IPv4 confirmed (No CGNAT)
#   1  CGNAT Detected
#   2  Possible CGNAT
#   3  Inconclusive
#   4  Internet unreachable
#   5  DNS failure
#   6  Internal error
#
# This script is a thin orchestration layer: all real logic lives in
# lib/*.sh so it can be independently unit tested.

set -o pipefail
set -u

# ---------------------------------------------------------------------------
# Resolve installation directory (so the tool works whether run from a
# git checkout, /usr/local/bin via symlink, or copied elsewhere).
# ---------------------------------------------------------------------------
resolve_script_dir() {
    local source="${BASH_SOURCE[0]}"
    while [[ -h "${source}" ]]; do
        local dir
        dir="$(cd -P "$(dirname "${source}")" >/dev/null 2>&1 && pwd)"
        source="$(readlink "${source}")"
        [[ "${source}" != /* ]] && source="${dir}/${source}"
    done
    cd -P "$(dirname "${source}")" >/dev/null 2>&1 && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
LIB_DIR="${SCRIPT_DIR}/lib"

# Exit code constants -- single source of truth, also read by
# lib/detect.sh's detect_status_exit_code() via ${CGNAT_EXIT_*:-default}.
# shellcheck disable=SC2034  # consumed indirectly by lib/detect.sh
readonly CGNAT_EXIT_PUBLIC=0
# shellcheck disable=SC2034
readonly CGNAT_EXIT_CGNAT=1
# shellcheck disable=SC2034
readonly CGNAT_EXIT_POSSIBLE_CGNAT=2
# shellcheck disable=SC2034
readonly CGNAT_EXIT_INCONCLUSIVE=3
# shellcheck disable=SC2034
readonly CGNAT_EXIT_NO_INTERNET=4
# shellcheck disable=SC2034
readonly CGNAT_EXIT_DNS_FAILURE=5
readonly CGNAT_EXIT_INTERNAL_ERROR=6

# shellcheck source=lib/colors.sh
source "${LIB_DIR}/colors.sh"
# shellcheck source=lib/version.sh
source "${LIB_DIR}/version.sh"
# shellcheck source=lib/utils.sh
source "${LIB_DIR}/utils.sh"
# shellcheck source=lib/network.sh
source "${LIB_DIR}/network.sh"
# shellcheck source=lib/detect.sh
source "${LIB_DIR}/detect.sh"
# shellcheck source=lib/traceroute.sh
source "${LIB_DIR}/traceroute.sh"
# shellcheck source=lib/json.sh
source "${LIB_DIR}/json.sh"
# shellcheck source=lib/output.sh
source "${LIB_DIR}/output.sh"

# ---------------------------------------------------------------------------
# CLI option defaults
# ---------------------------------------------------------------------------
OPT_JSON=false
OPT_VERBOSE=false
OPT_DEBUG=false
OPT_QUIET=false
OPT_IPV4_ONLY=false
OPT_IPV6_ONLY=false
OPT_TRACEROUTE=false
OPT_NO_UPNP=false

print_help() {
    cat <<EOF
${CGNAT_NAME} v${CGNAT_VERSION}
Detect Carrier Grade NAT (CGNAT) using multiple independent networking tests.

USAGE:
    cgnat-inspector [OPTIONS]

OPTIONS:
    --help          Show this help message and exit
    --version       Show version information and exit
    --json          Output machine-readable JSON instead of formatted text
    --verbose       Print additional detail about each test as it runs
    --debug         Print debug-level internal diagnostics
    --quiet         Suppress informational/log output (results still print)
    --ipv4-only     Skip all IPv6 tests
    --ipv6-only     Skip IPv4 public-address lookup (CGNAT detection itself
                    is inherently IPv4)
    --traceroute    Force traceroute analysis even if it would otherwise be
                    skipped, and include raw hop data in JSON output
    --no-upnp       Skip UPnP router WAN IP query

EXIT CODES:
    0  Public IPv4 confirmed (No CGNAT)    4  Internet unreachable
    1  CGNAT Detected                       5  DNS failure
    2  Possible CGNAT                       6  Internal error
    3  Inconclusive

Project home: ${CGNAT_REPO_URL}
EOF
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                print_help
                exit 0
                ;;
            --version|-v)
                print_version
                exit 0
                ;;
            --json)
                OPT_JSON=true
                ;;
            --verbose)
                OPT_VERBOSE=true
                ;;
            --debug)
                OPT_DEBUG=true
                OPT_VERBOSE=true
                ;;
            --quiet)
                OPT_QUIET=true
                ;;
            --ipv4-only)
                OPT_IPV4_ONLY=true
                ;;
            --ipv6-only)
                OPT_IPV6_ONLY=true
                ;;
            --traceroute)
                OPT_TRACEROUTE=true
                ;;
            --no-upnp)
                OPT_NO_UPNP=true
                ;;
            *)
                log_error "Unknown option: $1"
                printf 'Run "cgnat-inspector --help" for usage.\n' >&2
                exit "${CGNAT_EXIT_INTERNAL_ERROR}"
                ;;
        esac
        shift
    done

    if [[ "${OPT_IPV4_ONLY}" == "true" && "${OPT_IPV6_ONLY}" == "true" ]]; then
        log_error "--ipv4-only and --ipv6-only are mutually exclusive."
        exit "${CGNAT_EXIT_INTERNAL_ERROR}"
    fi
}

main() {
    parse_args "$@"

    VERBOSE="${OPT_VERBOSE}"
    DEBUG="${OPT_DEBUG}"
    QUIET="${OPT_QUIET}"

    # Colors must be disabled for JSON mode / redirected output.
    color_init "${OPT_JSON}"

    check_required_deps
    check_optional_deps

    log_verbose "Starting detection run..."

    # -------------------------------------------------------------------
    # Gather raw facts
    # -------------------------------------------------------------------
    local local_ip gateway public_ip="" public_ipv6=""
    local internet_ok=false gateway_ok=false dns_ok=false
    local ipv6_available=false

    local_ip=$(net_get_local_ip) || local_ip=""
    log_verbose "LAN IP: ${local_ip:-unknown}"

    gateway=$(net_get_gateway) || gateway=""
    log_verbose "Gateway: ${gateway:-unknown}"

    if net_check_internet; then
        internet_ok=true
        log_verbose "Internet: reachable"
    else
        log_verbose "Internet: unreachable"
    fi

    if [[ -n "${gateway}" ]] && net_check_gateway_reachable "${gateway}"; then
        gateway_ok=true
        log_verbose "Gateway: reachable"
    else
        log_verbose "Gateway: unreachable"
    fi

    # DNS is only meaningful to test once we know raw connectivity works;
    # otherwise a DNS failure is just a symptom of having no network at
    # all, not a distinct problem worth its own status/exit code.
    if [[ "${internet_ok}" == "true" && "${gateway_ok}" == "true" ]]; then
        if net_dns_resolves; then
            dns_ok=true
            log_verbose "DNS: resolving"
        else
            log_verbose "DNS: NOT resolving"
        fi
    fi

    if [[ "${internet_ok}" == "true" && "${dns_ok}" == "true" && "${OPT_IPV6_ONLY}" != "true" ]]; then
        public_ip=$(net_get_public_ipv4) || public_ip=""
        log_verbose "Public IPv4: ${public_ip:-Unavailable}"
    fi

    if [[ "${OPT_IPV4_ONLY}" != "true" && "${internet_ok}" == "true" && "${dns_ok}" == "true" ]]; then
        if public_ipv6=$(net_get_public_ipv6); then
            ipv6_available=true
        else
            public_ipv6=""
        fi
        log_verbose "Public IPv6: ${public_ipv6:-Not Available}"
    fi

    # Router WAN: UPnP only. If it cannot be obtained, it stays empty
    # and is reported honestly as "Unknown" -- never guessed from the
    # local LAN interface address (that was the bug this refactor
    # fixes: the LAN address is NOT the router's WAN address).
    local router_wan=""
    if [[ "${OPT_NO_UPNP}" != "true" && "${internet_ok}" == "true" ]]; then
        router_wan=$(net_get_router_wan_ip) || router_wan=""
        log_verbose "Router WAN (via UPnP): ${router_wan:-Unknown}"
    fi

    # STUN: independent, best-effort second opinion on the public
    # address. Never required; absence contributes no evidence either
    # way (see lib/detect.sh).
    local stun_ip=""
    if [[ "${internet_ok}" == "true" && "${dns_ok}" == "true" ]]; then
        stun_ip=$(net_stun_get_public_ip) || stun_ip=""
        log_verbose "STUN public IP: ${stun_ip:-unavailable}"
    fi

    # -------------------------------------------------------------------
    # Traceroute analysis (supporting evidence only)
    # -------------------------------------------------------------------
    local traceroute_output="" traceroute_ran=false
    local tr_private_hops=0 tr_public_hops=0 tr_backbone_private=false
    local run_traceroute=true
    if [[ "${internet_ok}" != "true" && "${OPT_TRACEROUTE}" != "true" ]]; then
        run_traceroute=false
    fi

    if [[ "${run_traceroute}" == "true" ]]; then
        traceroute_output=$(tr_run_traceroute "1.1.1.1" 8) || traceroute_output=""
        if [[ -n "${traceroute_output}" ]]; then
            traceroute_ran=true
            local tr_summary
            tr_summary=$(printf '%s\n' "${traceroute_output}" | tr_analyze "${gateway}")
            while IFS='=' read -r key value; do
                case "${key}" in
                    private_hops)     tr_private_hops="${value}" ;;
                    public_hops)      tr_public_hops="${value}" ;;
                    backbone_private) tr_backbone_private="${value}" ;;
                esac
            done <<< "${tr_summary}"
            log_verbose "Traceroute: ${tr_private_hops} private hop(s), ${tr_public_hops} public hop(s) beyond gateway"
        else
            log_verbose "Traceroute: unavailable or produced no output"
        fi
    fi

    # -------------------------------------------------------------------
    # Classification of gathered facts into evidence booleans
    # -------------------------------------------------------------------
    local router_wan_known=false router_wan_nonpublic=false
    local public_ip_known=false comparison_possible=false public_differs=false
    local stun_known=false stun_mismatch=false

    if [[ -n "${router_wan}" ]]; then
        router_wan_known=true
        if detect_is_non_public_ipv4 "${router_wan}"; then
            router_wan_nonpublic=true
        fi
    fi

    if [[ -n "${public_ip}" ]]; then
        public_ip_known=true
    fi

    if [[ "${router_wan_known}" == "true" && "${public_ip_known}" == "true" ]]; then
        comparison_possible=true
        if ! detect_addresses_match "${router_wan}" "${public_ip}"; then
            public_differs=true
        fi
    fi

    if [[ -n "${stun_ip}" ]]; then
        stun_known=true
        if [[ "${public_ip_known}" == "true" ]] && ! detect_addresses_match "${stun_ip}" "${public_ip}"; then
            stun_mismatch=true
        fi
    fi

    # "Multiple independent indicators" bonus: true when at least two
    # of the strong, independent signals agree.
    local strong_count=0
    [[ "${router_wan_nonpublic}" == "true" ]] && strong_count=$(( strong_count + 1 ))
    [[ "${public_differs}" == "true" ]] && strong_count=$(( strong_count + 1 ))
    [[ "${tr_backbone_private}" == "true" ]] && strong_count=$(( strong_count + 1 ))
    [[ "${stun_known}" == "true" && "${stun_mismatch}" == "true" ]] && strong_count=$(( strong_count + 1 ))
    local multiple_indicators=false
    (( strong_count >= 2 )) && multiple_indicators=true

    # -------------------------------------------------------------------
    # Scoring and final status
    # -------------------------------------------------------------------
    local score
    score=$(detect_compute_score \
        "${router_wan_known}" "${router_wan_nonpublic}" \
        "${public_ip_known}" "${public_differs}" \
        "${tr_backbone_private}" \
        "${stun_known}" "${stun_mismatch}" \
        "${ipv6_available}")

    local definitive_public=false
    if [[ "${router_wan_known}" == "true" && "${router_wan_nonpublic}" != "true" \
        && "${public_ip_known}" == "true" && "${public_differs}" != "true" ]]; then
        definitive_public=true
    fi

    local status
    status=$(detect_final_status "${internet_ok}" "${gateway_ok}" "${dns_ok}" "${definitive_public}" "${score}")

    # A definitive PUBLIC result has, by definition, no CGNAT evidence.
    # Likewise, when connectivity itself is broken (NO_INTERNET /
    # DNS_FAILURE), the numeric score is just leftover "uncertainty"
    # weight from evidence that couldn't be gathered -- not a
    # meaningful CGNAT confidence value -- so it's suppressed rather
    # than shown alongside a status it doesn't actually describe.
    case "${status}" in
        PUBLIC|NO_INTERNET|DNS_FAILURE)
            score=0
            ;;
    esac

    local conclusion
    conclusion=$(detect_conclusion "${status}")

    local recommendations
    recommendations=$(detect_recommendations "${status}" "${ipv6_available}")

    local evidence_lines
    evidence_lines=$(detect_build_evidence \
        "${internet_ok}" "${gateway_ok}" "${dns_ok}" \
        "${router_wan_known}" "${router_wan_nonpublic}" \
        "${public_ip_known}" "${comparison_possible}" "${public_differs}" \
        "${traceroute_ran}" "${tr_backbone_private}" \
        "${stun_known}" "${stun_mismatch}" \
        "${ipv6_available}" "${multiple_indicators}")

    # -------------------------------------------------------------------
    # Output
    # -------------------------------------------------------------------
    if [[ "${OPT_JSON}" == "true" ]]; then
        local json_traceroute_hops=""
        if [[ "${OPT_TRACEROUTE}" == "true" ]]; then
            json_traceroute_hops="${traceroute_output}"
        fi

        json_build_report \
            "${status}" \
            "${score}" \
            "${local_ip}" \
            "${gateway}" \
            "${router_wan}" \
            "${public_ip}" \
            "${public_ipv6:-}" \
            "${evidence_lines}" \
            "${conclusion}" \
            "${recommendations}" \
            "${json_traceroute_hops}"
    else
        out_banner

        out_section_title "Network Information"
        out_kv "LAN IP" "${local_ip}"
        out_kv "Gateway" "${gateway}"
        out_kv "Router WAN" "${router_wan:-Unknown}"
        out_kv "Public IPv4" "${public_ip:-Unavailable}"
        out_kv "IPv6" "${public_ipv6:-Not Available}"

        if [[ -n "${traceroute_output}" ]]; then
            out_thin_rule
            printf '\n'
            out_section_title "Traceroute"
            printf '%s\n' "${traceroute_output}" | tr_format_for_display
            printf '\n'
        fi

        out_rule
        printf '\nAssessment\n\n'
        out_rule
        printf '\n'

        printf 'Status\n\n'
        out_status_line "${status}"
        printf '\n'

        printf 'Confidence\n\n'
        out_confidence_line "${score}"
        printf '\n'

        printf 'Evidence\n\n'
        printf '%s\n' "${evidence_lines}" | out_evidence_checklist
        printf '\n'

        printf 'Conclusion\n\n%s\n\n' "${conclusion}"

        printf 'Recommendations\n\n'
        printf '%s\n' "${recommendations}" | out_recommendations
        printf '\n'

        printf 'Exit Code\n\n%s\n' "$(detect_status_exit_code "${status}")"
    fi

    exit "$(detect_status_exit_code "${status}")"
}

main "$@"
